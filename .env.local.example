# Paybook — environment variables
# Copy to .env.local and fill in the values from your Supabase project:
#   Dashboard → Project Settings → API
#
# paybook project ref: xzscylijovlgfclfofvp

# Public — safe to expose to the browser (anon key is RLS-protected)
NEXT_PUBLIC_SUPABASE_URL=https://xzscylijovlgfclfofvp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. Bypasses RLS.
# Used exclusively in server actions (audit_log writes, privileged ops).
SUPABASE_SERVICE_ROLE_KEY=

# Daily briefing cron (Vercel cron sends this as a Bearer token).
# Set the same value in the Vercel project's environment variables.
CRON_SECRET=

# WhatsApp Business API via Twilio. Until all three are set, the daily briefing
# dispatch runs but does not deliver (it records + retries).
# TWILIO_WHATSAPP_FROM is the sender, e.g. whatsapp:+14155238886 (sandbox or your
# approved WhatsApp sender).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
