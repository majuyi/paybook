# Paybook — environment variables
# Copy to .env.local and fill in the values from your Supabase project:
#   Dashboard → Project Settings → API
#
# paybook project ref: xzscylijovlgfclfofvp

# Public — safe to expose to the browser (anon key is RLS-protected)
NEXT_PUBLIC_SUPABASE_URL=https://xzscylijovlgfclfofvp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER expose to the browser. Bypasses RLS.
# Used exclusively in server actions (audit_log writes, privileged ops).
SUPABASE_SERVICE_ROLE_KEY=
